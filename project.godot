; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="2D横版类银河恶魔城"
run/main_scene="uid://ctrdcgddey34q"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="uid://copoux07qo0pc"

[autoload]

SceneManager="*res://00_global/scene_manager/scene_manager.tscn"
SaveManager="*res://00_global/save_manager.gd"
Messages="*res://00_global/messages.gd"
PlayerHud="*res://00_global/player_hud/player_hud.tscn"
Audio="*res://00_global/audio/audio.tscn"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1440
window/size/window_height_override=810
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdfxr/plugin.cfg")

[file_customization]

folder_colors={
"res://components/": "green",
"res://music/": "yellow"
}

[global_group]

Player=""

